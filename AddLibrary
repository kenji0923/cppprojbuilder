#!/bin/sh


if [ $# -ne 2 ]; then
  echo "Usage : $(basename "$0") project_name library_name"
  exit 1
fi


# Resolve the real script location, following symlinks, so this works when
# AddLibrary is symlinked onto PATH.
script_path=$(readlink -f "$0")
script_dir=$(dirname "$script_path")
template_lib_dir="$script_dir/template/library"

project_name="$1"
library_name="$2"

core_dir="${project_name}/src/core"
include_dir="${core_dir}/include/${project_name}"


if [ ! -d "${core_dir}" ]; then
  echo "Error: ${core_dir} not found. Run CreateCppProject ${project_name} first."
  exit 1
fi


mkdir -p "${include_dir}"

header="${include_dir}/${library_name}.h"
source="${core_dir}/${library_name}.cc"

cp "${template_lib_dir}/VAR_LIBRARY_NAME.h" "${header}"
cp "${template_lib_dir}/VAR_LIBRARY_NAME.cc" "${source}"

for f in "${header}" "${source}"; do
  sed -i \
    -e "s/VAR_PROJECT_NAME/${project_name}/g" \
    -e "s/VAR_LIBRARY_NAME/${library_name}/g" \
    "$f"
done


cat <<EOF
Created:
  ${header}
  ${source}

Add this to ${core_dir}/CMakeLists.txt (before ${project_name}_install_package()):
  ${project_name}_add_library_std(${library_name} ${library_name})
EOF
